# Telegram API credentials
# Получите на https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Источники (через запятую, можно username или ID)
SOURCE_CHANNELS=-1001234567890,@channel_username

# Целевой канал (username или ID)
TARGET_CHANNEL=-1009876543210

# Ссылка для замены всех кликабельных элементов
MY_LINK=https://example.com/

# Задержка для группировки альбомов (в секундах)
ALBUM_DELAY_SECONDS=2
