[Unit]
Description=Telegram Mirror Bot
After=network.target

[Service]
Type=simple
User=YOUR_USERNAME
WorkingDirectory=/home/YOUR_USERNAME/tgparsnurxa
Environment="PATH=/home/YOUR_USERNAME/tgparsnurxa/venv/bin"
ExecStart=/home/YOUR_USERNAME/tgparsnurxa/venv/bin/python3 mirror_userbot.py
Restart=always
RestartSec=10
StandardOutput=append:/home/YOUR_USERNAME/tgparsnurxa/log.txt
StandardError=append:/home/YOUR_USERNAME/tgparsnurxa/log.txt

[Install]
WantedBy=multi-user.target
